# ──────────────────────────────────────────────────────────────────────────────
# Human ReID Service — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (with pgvector extension installed)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reid_db

# Port the uvicorn server listens on (default: 8001)
PORT=8001
